# Copy this file to ".env" and fill in real values. .env is git-ignored — never commit it.

# ---------- Backblaze B2 (Step 1) ----------
B2_KEY_ID=
B2_APP_KEY=
B2_BUCKET=trueprint
B2_S3_ENDPOINT=        # e.g. s3.us-west-004.backblaze.com
B2_REGION=             # e.g. us-west-004

# ---------- GMI Cloud (Step 2) ----------
GMI_API_KEY=
GMI_BASE_URL=          # from the GMI console/docs
GMI_MODEL_VISION=      # multimodal/vision model id
GMI_MODEL_IMAGE=       # image-to-image / restoration model id
GMI_MODEL_AUDIO=       # audio denoise/restore or TTS model id

# ---------- Google (Gemini image — independent 2nd colorizer, true multi-provider) ----------
GOOGLE_API_KEY=            # Google AI Studio key (aistudio.google.com); enables the primary colorizer
GOOGLE_MODEL_IMAGE=gemini-3.1-flash-image

# ---------- Optional extra providers ----------
OPENAI_API_KEY=
ELEVENLABS_API_KEY=
